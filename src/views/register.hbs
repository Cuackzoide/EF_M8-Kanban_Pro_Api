<main class="container py-3 flex-fill">
    <h1 class="text-center text-warning mb-3">
        Registrarse
    </h1>
    <div class="card px-3 pt-3">
        <form action="/api/auth/register" method="post">
            <div class="mb-3">
                <label for="name" class="form-label">Usuario</label>
                <input type="text" class="form-control" id="name" name="name">
            </div>
            <div class="mb-3">
                <label for="email" class="form-label">Correo Electrónico</label>
                <input type="email" class="form-control" id="email" name="email">
            </div>
            <div class="mb-3">
                <label for="password" class="form-label">Contraseña</label>
                <input type="password" class="form-control" id="password" name="password">
            </div>
            <button type="submit" class="btn btn-info">Registrarse</button>
        </form>
        <hr>
        <p>
            <small>o si ya tienes tu cuenta</small>
            <a class="btn btn-sm btn-warning" href="/login">Iniciar Sesión</a>
        </p>
    </div>
</main>