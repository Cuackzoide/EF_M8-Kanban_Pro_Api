<main class="container py-3 flex-fill">
    <h1 class="text-center mb-4">Bienvenido {{user.name}}!</h1>
    
    <div class="card mb-4 shadow-sm border-info">
        <div class="card-body d-flex align-items-center gap-3">
            <h5 class="card-title m-0 p-0 text-info">Crear un Nuevo Tablero</h5>
            <form action="/api/board" method="POST" class="d-flex gap-2 flex-grow-1">
                <input type="text" class="form-control" name="title" placeholder="Ej: Nuevo Proyecto..." required>
                <button type="submit" class="btn btn-info text-white text-nowrap"><i class="bi bi-plus-circle me-1"></i> Añadir Tablero</button>
            </form>
        </div>
    </div>

    <div class="card my-3 bg-transparent border-0">
        {{#each tableros}}
        <div class="card mb-4 shadow-sm">
            <div class="card-header accordion bg-white" id="accordion{{this.id}}">
                <div class="accordion-item border-0">
                    <div class="accordion-header">
                        <button class="accordion-button collapsed fw-bold fs-4 text-dark" type="button" data-bs-toggle="collapse"
                            data-bs-target="#collapse{{this.id}}" aria-expanded="false" aria-controls="collapse{{this.id}}">
                            {{this.title}}
                        </button>
                    </div>
                    <div id="collapse{{this.id}}" class="accordion-collapse collapse"
                        data-bs-parent="#accordion{{this.id}}">
                        <div class="accordion-body d-flex flex-column flex-md-row gap-2 align-items-md-center px-3">
                            <form action="/api/board/{{this.id}}?_method=PUT" method="POST"
                                class="d-flex gap-2 align-items-center flex-grow-1 m-0">
                                <input type="text" name="title" class="form-control form-control-sm" value="{{this.title}}"
                                    required>
                                <button type="submit" class="btn btn-sm btn-outline-info text-nowrap" style="min-width: 110px;">
                                    <i class="bi bi-pencil"></i> Editar
                                </button>
                            </form>
                            <form action="/api/board/{{this.id}}?_method=DELETE" method="POST" class="m-0">
                                <button type="submit" class="btn btn-sm btn-outline-danger text-nowrap w-100" style="min-width: 110px;">
                                    <i class="bi bi-trash"></i> Eliminar
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="card-body bg-light rounded-bottom">
                <div class="d-flex align-items-center gap-3 mb-4 bg-white p-3 rounded shadow-sm border-start border-info border-4">
                    <h6 class="m-0 text-info fw-bold text-nowrap"><i class="bi bi-card-text me-1"></i> Nueva Tarea</h6>
                    <form action="/api/newcard" method="POST" class="d-flex gap-2 flex-grow-1 m-0">
                        <input type="hidden" name="listId" value="{{this.listas.[0].id}}">
                        <input type="text" class="form-control form-control-sm" name="cardTitle" placeholder="Ej: Nueva Tarea..." required>
                        <button type="submit" class="btn btn-sm btn-info text-white text-nowrap"><i class="bi bi-plus-circle me-1"></i> Añadir</button>
                    </form>
                </div>

                <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-3">
                    {{#each this.listas}}
                    <div class="col">
                        <div class="card h-100 border-0 shadow-sm rounded-3">
                            <div class="card-header bg-info text-white fw-bold rounded-top-3 text-center fs-5 py-3 border-0">
                                {{this.title}}
                            </div>
                            
                            <div class="card-body p-2 bg-light">
                                <ul class="list-group list-group-flush gap-2" style="min-height: 120px;">
                                    {{#each this.tarjetas}}
                                    <li class="list-group-item d-flex flex-column gap-2 border rounded p-2 shadow-sm">
                                        <div class="d-flex gap-2 align-items-start">
                                            <form action="/api/card/{{this.id}}?_method=PUT" method="POST"
                                                class="d-flex gap-2 align-items-center flex-grow-1">
                                                <input type="text" name="title" class="form-control border-0 fw-semibold bg-transparent px-1"
                                                    value="{{this.title}}" required>
                                                <button type="submit" class="btn btn-sm btn-link text-info p-0"><i
                                                        class="bi bi-pencil"></i></button>
                                            </form>
                                            <form action="/api/card/{{this.id}}?_method=DELETE" method="POST" class="m-0">
                                                <button type="submit" class="btn btn-sm btn-link text-danger p-0"><i
                                                        class="bi bi-trash"></i></button>
                                            </form>
                                        </div>
                                        <div class="d-flex align-items-center gap-1 justify-content-end mt-1 border-top pt-1">
                                            <form action="/api/card/{{this.id}}?_method=PUT" method="POST" class="m-0">
                                                <input type="hidden" name="title" value="{{this.title}}">
                                                <input type="hidden" name="listId" value="{{../prevListId}}">
                                                <button type="submit" class="btn btn-sm btn-outline-warning rounded-pill py-0 px-2" {{#if ../disableBack}}disabled{{/if}} title="Mover atrás"><i class="bi bi-arrow-left"></i></button>
                                            </form>

                                            <form action="/api/card/{{this.id}}?_method=PUT" method="POST" class="m-0">
                                                <input type="hidden" name="title" value="{{this.title}}">
                                                <input type="hidden" name="listId" value="{{../nextListId}}">
                                                <button type="submit" class="btn btn-sm btn-outline-info rounded-pill py-0 px-2" {{#if ../disableNext}}disabled{{/if}} title="Mover adelante"><i class="bi bi-arrow-right"></i></button>
                                            </form>
                                        </div>
                                    </li>
                                    {{else}}
                                    <li class="list-group-item text-center p-4 text-muted bg-transparent border-1 rounded">
                                        <small><i class="bi bi-inbox fs-4 d-block mb-1 text-secondary"></i>Sin tareas</small>
                                    </li>
                                    {{/each}}
                                </ul>
                            </div>

                        </div>
                    </div>
                    {{/each}}
                </div>
            </div>
        </div>
        {{else}}
        <div class="text-center py-5 text-muted">
            <i class="bi bi-kanban fs-1"></i>
            <h4>Aún no tienes tableros</h4>
            <p>Crea tu primer tablero en el formulario de arriba para empezar.</p>
        </div>
        {{/each}}
    </div>
</main>